// Stock Research dashboard schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Listed company master (synced from J-Quants /listed/info)
model ListedStock {
  code            String   @id // 5桁コード (J-Quants形式、例: "13010")
  ticker          String   // 4桁短縮形 (検索用、例: "1301")
  name            String
  nameEnglish     String?
  sector33Code    String?
  sector33Name    String?
  sector17Code    String?
  sector17Name    String?
  scaleCategory   String?  // TOPIX区分 (Core30, Large70, Mid400, Small1, Small2 等)
  marketCode      String?  // 市場区分コード
  marketName      String?  // プライム/スタンダード/グロース等
  updatedAt       DateTime @updatedAt

  prices     PriceCache[]
  watchItems Watchlist[]
  financials FinancialCache[]
  forecast   Forecast?
  history    BrowseHistory[]

  @@index([ticker])
  @@index([name])
}

// Daily OHLCV cache (12週遅延データ on free plan)
model PriceCache {
  code   String
  date   DateTime
  open   Float
  high   Float
  low    Float
  close  Float
  volume Float

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)

  @@id([code, date])
  @@index([code, date])
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  note      String?
  createdAt DateTime @default(now())

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)
}

// Browsing history - last viewed stocks
model BrowseHistory {
  code       String   @id
  lastViewed DateTime @default(now())

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)

  @@index([lastViewed])
}

// Latest company-issued forecast (1 row per code, replaced on each sync)
// Source: J-Quants /fins/summary F-prefix fields on most recent quarterly disclosure
model Forecast {
  code               String   @id
  forFiscalYearEnd   String   // YYYY-MM-DD that the forecast targets
  disclosedDate      String   // YYYY-MM-DD when forecast was issued
  netSales           Float?
  operatingProfit    Float?
  ordinaryProfit     Float?
  netIncome          Float?
  eps                Float?
  dividendAnnual     Float?
  // Implied YoY vs the most recent actual FY
  salesYoYImplied    Float?
  profitYoYImplied   Float?
  updatedAt          DateTime @updatedAt

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)
}

// Annual financial cache (for screening; 1 row per code+fiscal-year-end)
model FinancialCache {
  code              String
  fiscalYearEnd     String   // "YYYY-MM-DD"
  netSales          Float?
  operatingProfit   Float?
  ordinaryProfit    Float?
  netIncome         Float?
  eps               Float?
  totalAssets       Float?
  equity            Float?
  equityRatio       Float?
  bookValuePerShare Float?
  dividend          Float?
  // Convenience: pre-computed YoY (vs previous FY in same code), null when no prior
  salesYoY          Float?   // % e.g. 12.5
  profitYoY         Float?
  updatedAt         DateTime @updatedAt

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)

  @@id([code, fiscalYearEnd])
  @@index([code])
}

// Sync log to know last fetch times
model SyncLog {
  key       String   @id // "listed_info" | "prices:{code}" | "financials:{code}" | "id_token"
  payload   String?
  syncedAt  DateTime @updatedAt
}
