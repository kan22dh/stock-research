// Stock Research dashboard schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Listed company master (synced from J-Quants /listed/info)
model ListedStock {
  code            String   @id // 5桁コード (J-Quants形式、例: "13010")
  ticker          String   // 4桁短縮形 (検索用、例: "1301")
  name            String
  nameEnglish     String?
  sector33Code    String?
  sector33Name    String?
  sector17Code    String?
  sector17Name    String?
  scaleCategory   String?  // TOPIX区分 (Core30, Large70, Mid400, Small1, Small2 等)
  marketCode      String?  // 市場区分コード
  marketName      String?  // プライム/スタンダード/グロース等
  updatedAt       DateTime @updatedAt

  prices     PriceCache[]
  watchItems Watchlist[]
  financials FinancialCache[]
  forecast   Forecast?
  history    BrowseHistory[]
  momentum   Momentum?
  positions  Position[]
  signals    Signal[]

  @@index([ticker])
  @@index([name])
}

// Daily OHLCV cache — Yahoo-sourced (split-adjusted). adjClose additionally
// includes dividends; the backtest uses it so strategy vs benchmark is a fair
// total-return comparison. Display charts keep `close` (actual price levels).
model PriceCache {
  code     String
  date     DateTime
  open     Float
  high     Float
  low      Float
  close    Float
  adjClose Float?
  volume   Float

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)

  @@id([code, date])
  @@index([code, date])
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  note      String?
  createdAt DateTime @default(now())

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)
}

// Browsing history - last viewed stocks
model BrowseHistory {
  code       String   @id
  lastViewed DateTime @default(now())

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)

  @@index([lastViewed])
}

// Latest company-issued forecast (1 row per code, replaced on each sync)
// Source: J-Quants /fins/summary F-prefix fields on most recent quarterly disclosure
model Forecast {
  code               String   @id
  forFiscalYearEnd   String   // YYYY-MM-DD that the forecast targets
  disclosedDate      String   // YYYY-MM-DD when forecast was issued
  netSales           Float?
  operatingProfit    Float?
  ordinaryProfit     Float?
  netIncome          Float?
  eps                Float?
  dividendAnnual     Float?
  // Implied YoY vs the most recent actual FY
  salesYoYImplied    Float?
  profitYoYImplied   Float?
  updatedAt          DateTime @updatedAt

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)
}

// Annual financial cache (for screening; 1 row per code+fiscal-year-end)
model FinancialCache {
  code              String
  fiscalYearEnd     String   // "YYYY-MM-DD"
  netSales          Float?
  operatingProfit   Float?
  ordinaryProfit    Float?
  netIncome         Float?
  eps               Float?
  totalAssets       Float?
  equity            Float?
  equityRatio       Float?
  bookValuePerShare Float?
  dividend          Float?
  // Convenience: pre-computed YoY (vs previous FY in same code), null when no prior
  salesYoY          Float?   // % e.g. 12.5
  profitYoY         Float?
  updatedAt         DateTime @updatedAt

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)

  @@id([code, fiscalYearEnd])
  @@index([code])
}

// Sync log to know last fetch times
model SyncLog {
  key       String   @id // "listed_info" | "prices:{code}" | "financials:{code}" | "id_token"
  payload   String?
  syncedAt  DateTime @updatedAt
}

// Price-momentum snapshot per stock, refreshed from Yahoo Finance (no J-Quants
// rate-limit concerns). Powers RS Rating (percentile, computed at read-time
// across all rows) and Minervini Trend Template technical scoring.
model Momentum {
  code           String   @id
  price          Float?
  return1m       Float?   // %
  return3m       Float?   // %
  return6m       Float?   // %
  return9m       Float?   // %
  return12m      Float?   // %
  rsRaw          Float?   // IBD-style weighted momentum ratio: (2*Q1+Q2+Q3+Q4)/5
  ma50           Float?
  ma150          Float?
  ma200          Float?
  high52w        Float?
  low52w         Float?
  // Technical Trend Template conditions excluding RS Rating (0-7; the 8th
  // condition, RS Rating >= 70, is combined at read-time once percentiles
  // across the universe are known).
  technicalScore Int      @default(0)
  technicalPass  Boolean  @default(false)
  // VCP (volatility contraction pattern) heuristic — the "entry technique"
  // side of Minervini's method. pivot = breakout trigger price (10-day high).
  vcpPass        Boolean  @default(false)
  vcpTightness   Float?   // 10-day normalized range; smaller = tighter
  vcpVolumeDryUp Boolean  @default(false)
  pivot          Float?
  asOf           DateTime @updatedAt

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)
}

// Actual held positions (not just watchlist) — shares, cost basis, stop-loss.
model Position {
  id            Int       @id @default(autoincrement())
  code          String
  shares        Float
  entryPrice    Float
  entryDate     DateTime
  stopLossPrice Float?
  targetPrice   Float?
  status        String    @default("open") // "open" | "closed"
  closePrice    Float?
  closeDate     DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stock   ListedStock    @relation(fields: [code], references: [code], onDelete: Cascade)
  journal JournalEntry[]

  @@index([code])
  @@index([status])
}

// Buy/sell/note journal tied to a position — records the thesis and outcome.
model JournalEntry {
  id         Int      @id @default(autoincrement())
  positionId Int
  type       String   // "buy" | "sell" | "note"
  reason     String
  createdAt  DateTime @default(now())

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId])
}

// Small key-value store for goal config (target amount, cash balance, etc.)
model AppSetting {
  key   String @id
  value String
}

// Daily signal feed, produced by the morning cron (/api/daily-refresh):
// "pivot_breakout" — yesterday's VCP stock closed above its pivot
// "vcp_new"        — stock newly entered VCP setup (watch candidate)
// "stop_raise"     — open position advanced; suggest raising the stop-loss
model Signal {
  id        Int      @id @default(autoincrement())
  date      String   // YYYY-MM-DD (JST) batch date
  type      String
  code      String
  payload   String?  // JSON details (pivot, price, suggested stop, ...)
  createdAt DateTime @default(now())

  stock ListedStock @relation(fields: [code], references: [code], onDelete: Cascade)

  @@unique([date, type, code])
  @@index([date])
}
